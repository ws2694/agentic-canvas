# Primary provider — get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional fallback provider. If set, the agent falls back to OpenAI when every
# Claude tier is rate-limited, overloaded, or out of credits.
# Get a key at https://platform.openai.com
OPENAI_API_KEY=

# Optional: override the model chains (comma-separated ids).
# AGENT_MODELS=claude-opus-4-8,claude-sonnet-4-6,claude-haiku-4-5
# OPENAI_MODELS=gpt-4o
